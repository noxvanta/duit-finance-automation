      "parameters": {
        "jsCode": "// 1. Ambil data dari node AI Agent\nconst inputItem = $input.first();\nlet rawData = inputItem.json?.output || inputItem.json?.text || inputItem.json?.content || \"\";\nconst aiResponse = String(rawData);\n\n// Mencari pola array JSON [ ... ] di dalam teks (karena AI sering memberi teks tambahan)\nconst jsonRegex = /\\[[\\s\\S]*\\]/;\nconst match = aiResponse.match(jsonRegex);\nlet cleanJson = \"\";\n\nif (match) {\n    cleanJson = match[0].trim();\n} else {\n    cleanJson = aiResponse.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n}\n\nlet dataList = [];\nlet replyMessage = \"\";\n\ntry {\n    // 2. Parsing JSON dari AI\n    const parsed = JSON.parse(cleanJson);\n    dataList = Array.isArray(parsed) ? parsed : [parsed];\n\n    // Persiapkan Waktu Indonesia (WIB)\n    const now = new Date();\n    const wibTime = new Date(now.getTime() + (7 * 60 * 60 * 1000));\n    const tanggalDefault = wibTime.toISOString().split('T')[0]; \n    const waktuDefault = wibTime.toISOString().split('T')[1].substring(0, 8); \n\n    // 3. MAPPING DATA\n    const processedData = dataList.map(item => {\n        // Sanitasi Harga: Menghapus karakter non-angka\n        let val = item.Harga ?? item.harga ?? item.Jumlah ?? item.jumlah ?? \"0\";\n        let hargaMentah = val.toString().replace(/\\D/g, '');\n        let harga = parseInt(hargaMentah) || 0;\n\n        let tgl = item.Tanggal || item.tanggal || tanggalDefault;\n        let wkt = item.Waktu || item.waktu || waktuDefault;\n        let namaItem = item.Keterangan || item.keterangan || \"Tanpa Keterangan\";\n        let kategori = item.Kategori || item.kategori || \"Lainnya\";\n        let jenis = item.Jenis || item.jenis || \"Pengeluaran\";\n        \n        // Deteksi Aksi (insert/update/delete)\n        let aksi = item.aksi || \"insert\"; \n\n        // Setel Emoji dan Status Teks berdasarkan aksi\n        let statusEmoji = \"📌\";\n        let statusTeks = \"\";\n        \n        if (aksi === \"delete\") {\n            statusEmoji = \"🗑️\";\n            statusTeks = \"DIHAPUS\";\n        } else if (aksi === \"update\") {\n            statusEmoji = \"🔄\";\n            statusTeks = \"DIPERBARUI\";\n        }\n\n        return {\n            aksi: aksi,\n            tanggal: tgl,\n            waktu: wkt,\n            keterangan: namaItem,\n            kategori: kategori,\n            jenis: jenis,\n            harga: harga,\n            update_target: item.update_target ?? namaItem, \n            formatted_text: `\\n${statusEmoji} *${namaItem}* ${statusTeks} (${kategori})\\n💰 Rp ${harga.toLocaleString('id-ID')}`\n        };\n    });\n\n    // 4. SUSUN PESAN BALASAN\n    if (processedData.length > 0) {\n        replyMessage = \"✅ *DATA TERCATAT!*\";\n        \n        // Tambahkan rincian barang\n        processedData.forEach(d => { \n            replyMessage += d.formatted_text; \n        });\n\n        // LOGIKA TOTAL: Hanya muncul jika item lebih dari satu (Multi-item)\n        if (processedData.length > 1) {\n            const total = processedData.reduce((sum, d) => sum + d.harga, 0);\n            replyMessage += `\\n\\n──────────────\\n💵 *TOTAL: Rp ${total.toLocaleString('id-ID')}*`;\n        }\n    }\n\n    return {\n        json: {\n            reply_message: replyMessage,\n            sheet_data: processedData, \n            chat_id: inputItem.json?.chat_id || inputItem.json?.message?.chat?.id\n        }\n    };\n\n} catch (error) {\n    // Jika AI hanya mengirim teks (curhat), kirim apa adanya tanpa memproses JSON\n    return {\n        json: {\n            reply_message: aiResponse, \n            sheet_data: [], \n            chat_id: inputItem.json?.chat_id || inputItem.json?.message?.chat?.id\n        }\n    };\n}"
      },
